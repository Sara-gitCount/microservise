.env.example
# Copy this file to .env and update values for your environment

# ============ SQL SERVER ============
MSSQL_SA_PASSWORD=YourPasswordHere123!
MSSQL_DATABASE=Mechira-sinit-microservices

# ============ AUTHENTICATION ============
JWT_SECRET_KEY=your-super-secret-key-that-must-be-at-least-32-characters-long-for-hmac256
JWT_ISSUER=AuthService
JWT_AUDIENCE=MicroservicesApi
JWT_EXPIRY_MINUTES=60

# ============ SERVICE URLS (Internal Docker DNS) ============
AUTH_SERVICE_URL=http://auth-service:5001
CATALOG_SERVICE_URL=http://catalog-service:5002
ORDER_SERVICE_URL=http://order-service:5003
LOTTERY_SERVICE_URL=http://lottery-service:5004

# ============ DOCKER ENVIRONMENT ============
ASPNETCORE_ENVIRONMENT=Production

# ============ EXTERNAL PORTS ============
# These are ports exposed to the host machine
GATEWAY_PORT=5000
AUTH_SERVICE_PORT=5001
CATALOG_SERVICE_PORT=5002
ORDER_SERVICE_PORT=5003
LOTTERY_SERVICE_PORT=5004
MSSQL_PORT=1433
